        </node>
      </node>
      <node oor:name="fr.gouv.interieur.mirai.img.resize" oor:op="replace">
        <prop oor:name="URL" oor:type="xs:string">
          <value>service:fr.gouv.interieur.mirai.do?ResizeSelection&amp;src=toolbar</value>
        </prop>
        <node oor:name="UserDefinedImages">
          <prop oor:name="ImageSmallURL" oor:type="xs:string">
            <value>%origin%/icons/toolbar-resize_16.png</value>
          </prop>
          <prop oor:name="ImageBigURL" oor:type="xs:string">
            <value>%origin%/icons/toolbar-resize_26.png</value>
          </prop>
        </node>
      </node>
      <node oor:name="fr.gouv.interieur.mirai.img.summarize" oor:op="replace">
        <prop oor:name="URL" oor:type="xs:string">
          <value>service:fr.gouv.interieur.mirai.do?SummarizeSelection&amp;src=toolbar</value>
        </prop>
        <node oor:name="UserDefinedImages">
          <prop oor:name="ImageSmallURL" oor:type="xs:string">
            <value>%origin%/icons/toolbar-summarize_16.png</value>
          </prop>
          <prop oor:name="ImageBigURL" oor:type="xs:string">
            <value>%origin%/icons/toolbar-summarize_26.png</value>
          </prop>
        </node>
      </node>
      <node oor:name="fr.gouv.interieur.mirai.img.simplify" oor:op="replace">
        <prop oor:name="URL" oor:type="xs:string">
          <value>service:fr.gouv.interieur.mirai.do?SimplifySelection&amp;src=toolbar</value>
        </prop>
        <node oor:name="UserDefinedImages">
          <prop oor:name="ImageSmallURL" oor:type="xs:string">
            <value>%origin%/icons/toolbar-simplify_16.png</value>
          </prop>
          <prop oor:name="ImageBigURL" oor:type="xs:string">
            <value>%origin%/icons/toolbar-simplify_26.png</value>
          </prop>
        </node>
      </node>
      <node oor:name="fr.gouv.interieur.mirai.img.transform" oor:op="replace">
        <prop oor:name="URL" oor:type="xs:string">
          <value>service:fr.gouv.interieur.mirai.do?TransformToColumn&amp;src=toolbar</value>
        </prop>
        <node oor:name="UserDefinedImages">
          <prop oor:name="ImageSmallURL" oor:type="xs:string">
            <value>%origin%/icons/toolbar-transform_16.png</value>
          </prop>
          <prop oor:name="ImageBigURL" oor:type="xs:string">
            <value>%origin%/icons/toolbar-transform_26.png</value>
          </prop>
        </node>
      </node>
      <node oor:name="fr.gouv.interieur.mirai.img.formula" oor:op="replace">
        <prop oor:name="URL" oor:type="xs:string">
          <value>service:fr.gouv.interieur.mirai.do?GenerateFormula&amp;src=toolbar</value>
        </prop>
        <node oor:name="UserDefinedImages">
          <prop oor:name="ImageSmallURL" oor:type="xs:string">
            <value>%origin%/icons/toolbar-formula_16.png</value>
          </prop>
          <prop oor:name="ImageBigURL" oor:type="xs:string">
            <value>%origin%/icons/toolbar-formula_26.png</value>
          </prop>
        </node>
      </node>
